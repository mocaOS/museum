# Config for scripts/import-users.ts.
# Copy this file to scripts/.env and fill in the values.
# scripts/.env is gitignored.
#
# All values are required. If you wrap a value in single quotes, special
# characters like #, $, backticks, spaces, etc. are preserved literally.

# ── Superadmin login for the target deployment ───────────────────────────
# These must match the SUPERADMIN_EMAIL / SUPERADMIN_PASSWORD env on the
# running cortex-chat instance (visible in Coolify under the service's
# Environment Variables).
IMPORT_ADMIN_EMAIL=
IMPORT_ADMIN_PASSWORD=

# ── Target deployment ────────────────────────────────────────────────────
# Public URL of the cortex-chat instance, e.g. https://chat.example.com
IMPORT_URL=

# ── Source file ──────────────────────────────────────────────────────────
# Absolute path to the .xlsx file. First sheet, header row required.
# Columns must be lowercase: email, benutzername
IMPORT_FILE=

# ── Provisioning defaults ────────────────────────────────────────────────
# Group every imported user is added to. Must already exist on the target
# instance (create it via the admin UI first if not).
IMPORT_GROUP=KeyUser

# Password assigned to every newly created user. Communicate out-of-band
# and ask users to rotate it on first login.
IMPORT_DEFAULT_PASSWORD=
