# ============================================================================
# MOCA Museum — environment. Copy to .env (gitignored) and fill in.
# Deployed via docker-compose on Coolify/Dokploy. Dev runs on port 3331.
# ============================================================================

# --- Cortex (MOCA Library) ---------------------------------------------------
# Live Cortex backend. Server-only — the browser never calls it directly; all
# traffic goes through this app's /api/* proxy with the key injected.
CORTEX_API_URL=https://library.moca.qwellco.de

# Single museum Cortex key. Powers the PUBLIC Library (anonymous chat, searches
# all collections). Also used as the admin key unless one is set below.
# If unset, the museum still runs — only the Library is disabled.
CORTEX_API_KEY=

# Optional separate admin-tier key (minting per-group keys, /admin). Falls back
# to CORTEX_API_KEY when blank.
BACKEND_ADMIN_API_KEY=

# --- Directus (museum CMS: collections, NFTs, rooms) -------------------------
DIRECTUS_URL=https://api.moca.qwellco.de
IPFS_GATEWAY=https://ipfs.qwellcode.de/ipfs/

# --- Site ---------------------------------------------------------------------
# Canonical base URL for SEO / OpenGraph. Inlined at build time.
NEXT_PUBLIC_SITE_URL=https://museumofcryptoart.com

# --- Community / curation side (auth + admin) --------------------------------
SUPERADMIN_EMAIL=admin@museumofcryptoart.com
SUPERADMIN_PASSWORD=change-me
# 32 random bytes, base64: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# DATABASE_PATH=./data/museum.db
