# ============================================================================
# MOCA Museum — environment. Copy to .env (gitignored) and fill in.
# Deployed via docker-compose on Coolify/Dokploy. Dev runs on port 3331.
# ============================================================================

# --- Cortex (MOCA Library) ---------------------------------------------------
# Live Cortex backend. Server-only — the browser never calls it directly; all
# traffic goes through this app's /api/* proxy with the key injected.
CORTEX_API_URL=https://library.moca.qwellco.de

# Single read-only Cortex key. Powers the public, anonymous Library (chat +
# search across all collections the key can read). If unset, the museum still
# runs — only the Library is disabled.
CORTEX_API_KEY=

# --- Directus (museum CMS: collections, NFTs, rooms) -------------------------
DIRECTUS_URL=https://api.moca.qwellco.de
IPFS_GATEWAY=https://ipfs.qwellcode.de/ipfs/

# --- Site --------------------------------------------------------------------
# Canonical base URL for SEO / OpenGraph. Inlined at build time.
NEXT_PUBLIC_SITE_URL=https://museumofcryptoart.com

# --- Branding & analytics (optional — all have sensible MOCA defaults) -------
# APP_TITLE=MOCA Library
# APP_DESCRIPTION=
# ACCENT_COLOR=oklch(0.79 0.18 70.67)
# LOCALE=en                 # en | de
# LOGO_URL=                 # absolute URL; empty falls back to /logo.svg
# SUPPORT_URL=
# SUPPORT_LABEL=
# Static context block prepended to every Cortex request for agent skills.
# CORTEX_ANALYTICS_TEMPLATE=
