# ============================================================================
# MOCA Museum — environment. Copy to .env (gitignored) and fill in.
# Deployed via docker-compose on Coolify/Dokploy. Dev runs on port 3331.
# ============================================================================

# --- Cortex (MOCA Library) ---------------------------------------------------
# Live Cortex backend. Server-only — the browser never calls it directly; all
# traffic goes through this app's /api/* proxy with the key injected.
CORTEX_API_URL=https://library.moca.qwellco.de

# Single read-only Cortex key. Powers the public, anonymous Library (chat +
# search across all collections the key can read). If unset, the museum still
# runs — only the Library is disabled.
CORTEX_API_KEY=

# Management (write-capable, `cortex_rw_`) Cortex key — server-only. Used ONLY
# to ingest APPROVED community submissions into the Collective collection. Keep
# separate from the read-only key above. Unset → document approvals are disabled
# (submissions still queue, admins just can't publish them).
CORTEX_MANAGEMENT_API_KEY=

# Cortex collection that approved submissions are moved into. Created on first
# use if it doesn't exist.
CORTEX_COLLECTIVE_COLLECTION=Collective

# --- Directus (museum CMS: collections, NFTs, rooms) -------------------------
DIRECTUS_URL=https://api.moca.qwellco.de
IPFS_GATEWAY=https://ipfs.qwellcode.de/ipfs/

# Directus static token scoped to the `library_submissions` collection + file
# upload/read — server-only. This is the museum app's ONLY Directus writer; the
# submission review queue lives in Directus. Unset → submissions are disabled.
DIRECTUS_SUBMISSIONS_TOKEN=

# --- Site --------------------------------------------------------------------
# Canonical base URL for SEO / OpenGraph. Inlined at build time.
NEXT_PUBLIC_SITE_URL=https://museumofcryptoart.com

# --- Web3 wallet login + holdings --------------------------------------------
# Reown AppKit project id — powers the wallet connect modal (WalletConnect).
# Public value, inlined into the client bundle. Without it the modal won't open.
# Get one (free) at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# --- Document submissions + review (web3) ------------------------------------
# Secret for signing the SIWE session cookie (HMAC). Generate with e.g.
# `openssl rand -hex 32`. Unset → sign-in and submissions are disabled.
SESSION_SECRET=

# Comma-separated ETH addresses allowed to review/approve submissions (the
# reviewer whitelist). Case-insensitive. e.g. 0xabc...,0xdef...
LIBRARY_ADMIN_ADDRESSES=

# Moralis API key — server-only. Required to LIST the account view's NFT
# holdings (Art DeCC0s + MOCA ROOMs, with token ids + images). Without it the
# $MOCA balances still show; the NFT lists are just empty.
# Get one (free tier) at https://admin.moralis.com
MORALIS_API_KEY=

# JSON-RPC endpoints for reading $MOCA balances (server-only). Both fall back to
# a public endpoint if unset; a paid provider (Alchemy/Infura/dRPC) is steadier.
# ETH_RPC_URL is also used by the ROOMs owner lookup (room-owner.ts).
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com

# --- Branding & analytics (optional — all have sensible MOCA defaults) -------
# APP_TITLE=MOCA Library
# APP_DESCRIPTION=
# ACCENT_COLOR=oklch(0.79 0.18 70.67)
# LOCALE=en                 # en | de
# LOGO_URL=                 # absolute URL; empty falls back to /logo.svg
# SUPPORT_URL=
# SUPPORT_LABEL=
# Static context block prepended to every Cortex request for agent skills.
# CORTEX_ANALYTICS_TEMPLATE=
