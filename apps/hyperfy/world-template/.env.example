# Museum of Crypto Art — Hyperfy world template configuration.
# Copy to .env and fill in. See README.md for the full deploy guide.

# The world's admin key. Curators use it to spawn exhibitions from the
# museum world builder; admins use it in-world (`/admin <code>` in chat)
# to unlock build mode. Treat it like a password — anyone holding it can
# reshape the world.
ADMIN_CODE=

# Secret for the world's session tokens. Any long random string.
#   openssl rand -hex 32
JWT_SECRET=

# Public URLs browsers use to reach the world — your domain, not localhost.
# For local testing: ws://localhost:3400/ws etc.
PUBLIC_WS_URL=wss://your-world.example.com/ws
PUBLIC_API_URL=https://your-world.example.com/api
ASSETS_BASE_URL=https://your-world.example.com/assets

# Host port the container binds to (proxy your domain at this).
HOST_PORT=3400

# Optional tuning.
#SAVE_INTERVAL=30
#PUBLIC_MAX_UPLOAD_SIZE=64
#PUBLIC_PLAYER_COLLISION=false
#CLEAN=true
